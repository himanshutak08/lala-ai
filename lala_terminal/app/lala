#!/usr/bin/env python3

from rich.console import Console

console = Console()

console.print("[bold green]Lala Terminal[/bold green]")
console.print("Claude-style terminal for Home Assistant")
console.print("Type 'exit' to quit\n")

while True:

    prompt = input("lala > ")

    if prompt.lower() == "exit":
        break

    console.print(f"\n[cyan]You typed:[/cyan] {prompt}\n")